# Gemini dùng để tạo phụ đề SRT.
# Có thể để trống và nhập trực tiếp trong mục "API & mô hình AI" trên giao diện.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# RapidAPI dùng làm nguồn tải dự phòng cho một số link Douyin/TikTok.
# Nếu chỉ dùng YouTube hoặc upload file local thì có thể để trống.
RAPIDAPI_KEY=your_rapidapi_key_here

# OpenAI dùng cho chế độ lồng tiếng tự nhiên.
# Có thể để trống nếu chỉ dùng Microsoft Edge Neural hoặc nhập trực tiếp trên giao diện.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Cấu hình server local/LAN.
# HOST=0.0.0.0 cho phép máy khác cùng mạng LAN truy cập bằng IP máy chủ.
PORT=3210
HOST=0.0.0.0

# Tuỳ chọn nâng cao, chỉ cần bật nếu muốn dùng binary tự cài.
# FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe
# YTDLP_BIN=C:\yt-dlp\yt-dlp.exe
