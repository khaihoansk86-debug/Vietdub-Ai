{
  "name": "vietdub-ai-local",
  "version": "1.4.3",
  "description": "Ứng dụng Windows/local để tải, ghép, tạo phụ đề và lồng tiếng AI cho video.",
  "author": "VietDub AI",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "build:win": "electron-builder --win nsis",
    "check": "node --check server.js && node --check public/app.js && node --check electron/main.cjs"
  },
  "build": {
    "appId": "com.vietdub.ai",
    "productName": "VietDub AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "server.js",
      "package.json",
      "public/**/*",
      "electron/**/*",
      "node_modules/**/*",
      ".env.example"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/yt-dlp-exec/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "VietDub-AI-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VietDub AI"
    }
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "multer": "^2.1.1",
    "ws": "^8.21.0",
    "yt-dlp-exec": "^1.0.2"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  }
}
